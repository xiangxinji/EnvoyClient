{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EnvoyInstaller",
  "version": "0.1.0",
  "identifier": "com.envoy.installer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Envoy 安装程序",
        "width": 600,
        "height": 450,
        "decorations": false,
        "resizable": false,
        "center": true,
        "minWidth": 600,
        "minHeight": 450,
        "maxWidth": 600,
        "maxHeight": 450
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' img-src 'self' asset: https://asset.localhost data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": null
    }
  }
}
