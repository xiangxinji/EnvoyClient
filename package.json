{
  "name": "envoy-client",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "manager:server": "tsx manager/server/index.ts",
    "manager:web": "cd manager/web && npx vite",
    "manager": "concurrently -n server,web -c blue,green \"npm run manager:server\" \"npm run manager:web\""
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "dompurify": "^3.4.2",
    "marked": "^18.0.3",
    "vue": "^3.5.13",
    "vue-router": "^5.0.6",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/dompurify": "^3.0.5",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vue-tsc": "^2.1.10"
  }
}
