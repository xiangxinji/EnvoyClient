{
  "name": "envoy-client",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "npm@10.9.0",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "manager:server": "npm --prefix manager/server run start",
    "manager:web": "npm --prefix manager/web run dev",
    "manager": "concurrently -n server,web -c blue,green \"npm run manager:server\" \"npm run manager:web\"",
    "website:dev": "npm --prefix website run dev",
    "website:build": "npm --prefix website run build",
    "envoy:build": "npm --prefix envoy run build",
    "envoy:test": "npm --prefix envoy run test",
    "manager:server:test": "npm --prefix manager/server run test",
    "manager:web:build": "npm --prefix manager/web run build",
    "install:envoy": "npm --prefix envoy install",
    "install:manager:server": "npm --prefix manager/server install",
    "install:manager:web": "npm --prefix manager/web install",
    "install:website": "npm --prefix website install",
    "all:install": "npm install && npm run install:envoy && npm run install:manager:server && npm run install:manager:web && npm run install:website"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-global-shortcut": "^2.3.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2",
    "@tiptap/extension-document": "^3.23.4",
    "@tiptap/extension-hard-break": "^3.23.4",
    "@tiptap/extension-image": "^3.23.4",
    "@tiptap/extension-paragraph": "^3.23.4",
    "@tiptap/extension-placeholder": "^3.23.4",
    "@tiptap/extension-text": "^3.23.4",
    "@tiptap/pm": "^3.23.4",
    "@tiptap/vue-3": "^3.23.4",
    "@vueuse/motion": "^3.0.3",
    "dompurify": "^3.4.2",
    "marked": "^18.0.3",
    "vue": "^3.5.13",
    "vue-i18n": "^11.4.2",
    "vue-router": "^5.0.6",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/dompurify": "^3.0.5",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "concurrently": "^9.2.1",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vue-tsc": "^2.1.10"
  }
}
