{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    /* Envoy submodule path mapping */
    "paths": {
      "@envoy/core": ["./Envoy/packages/core/index.ts"],
      "@envoy/client": ["./Envoy/packages/client/index.ts"],
      "@envoy/teams": ["./Envoy/packages/teams/index.ts"]
    },
    "baseUrl": "."
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts", "src/**/*.tsx", "src/**/*.vue"],
  "exclude": ["Envoy/packages/server"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
